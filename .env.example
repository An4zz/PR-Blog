# Copy this file to `.env.local` (which is gitignored) and fill in the values
# from your Supabase project: Dashboard → Project Settings → API.
#
# The anon/public key is safe to expose in the client bundle — Row Level
# Security policies in the database gate all writes.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
